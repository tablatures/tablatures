# Base URL for the Search API
# Example: https://api.example.com/search
VITE_SEARCH_API_BASE_URL=

# Timeout for Search API requests (in milliseconds)
# Default: 10000 (10 seconds)
VITE_SEARCH_API_TIMEOUT=10000

# Deployment target (static for GitHub Pages, server for Vercel/SSR)
VITE_DEPLOY_TARGET=static

# Base path for the frontend (use '/' for root, '/repo' for GitHub Pages repo)
VITE_BASE_PATH=/tablatures